{
  "response": [
    {
      "name": "My Feature A",
      "slug": "feature-a",
      "isEnabled": true,
      "segments": [
        { "key": "license", "value": "trial" }
      ]
    },
    {
      "name": "My Feature B",
      "slug": "feature-b",
      "isEnabled": true,
      "segments": [
        { "key": "region", "value": "us" },
        { "key": "region", "value": "au" }
      ]
    },
    {
      "name": "My Feature C",
      "slug": "feature-c",
      "isEnabled": true,
      "segments": []
    },
    {
      "name": "My Feature D",
      "slug": "feature-d",
      "isEnabled": false,
      "segments": []
    }
  ],
  "cases": [
  {
    "description": "enabled when the evaluation context matches its required segment",
    "configuration": {
      "slug": "feature-a",
      "context": { "license": "trial" },
      "defaultValue": false
    },
    "expected": {
      "value": true
    }
  },
  {
    "description": "disabled when the evaluation context does not match its required segment",
    "configuration": {
      "slug": "feature-a",
      "context": { "license": "enterprise" },
      "defaultValue": false
    },
    "expected": {
      "value": false
    }
  },
  {
    "description": "disabled when no evaluation context is provided and toggle has required segments",
    "configuration": {
      "slug": "feature-a",
      "context": {},
      "defaultValue": false
    },
    "expected": {
      "value": false
    }
  },
  {
    "description": "enabled when context matches one value from a multi-value segment key",
    "configuration": {
      "slug": "feature-b",
      "context": { "region": "us" },
      "defaultValue": false
    },
    "expected": {
      "value": true
    }
  },
  {
    "description": "enabled regardless of context when toggle has no required segments",
    "configuration": {
      "slug": "feature-c",
      "context": {},
      "defaultValue": false
    },
    "expected": {
      "value": true
    }
  },
  {
    "description": "disabled when toggle is not enabled regardless of context",
    "configuration": {
      "slug": "feature-d",
      "context": {},
      "defaultValue": false
    },
    "expected": {
      "value": false
    }
  },
  {
    "description": "returns FLAG_NOT_FOUND and default value when flag key is not a slug",
    "configuration": {
      "slug": "not a slug",
      "context": {},
      "defaultValue": true
    },
    "expected": {
      "value": true,
      "errorCode": "FLAG_NOT_FOUND"
    }
  },
  {
    "description": "returns FLAG_NOT_FOUND and default value when slug does not match any toggle",
    "configuration": {
      "slug": "unknown-feature",
      "context": {},
      "defaultValue": true
    },
    "expected": {
      "value": true,
      "errorCode": "FLAG_NOT_FOUND"
    }
  }
]

